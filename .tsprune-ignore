# Baseline ignore for ts-prune (one pattern per line).
# Match export identity only — CI strips ":line" before comparing so edits
# that shift line numbers do not fail deadcode.
#
# Format: <path> - <export name>[ (used in module)]

# App root default export (wired via main.tsx)
src/App.tsx - default
# ContentItem is the BlogCard content union; used within the module
src/components/BlogCard.tsx - ContentItem (used in module)
# Shared types: nested interfaces used within the module; Job/Role imported by JobCard/jobs
src/types/index.ts - Paragraph (used in module)
src/types/index.ts - Achievement (used in module)
src/types/index.ts - Role (used in module)
src/types/index.ts - Job
